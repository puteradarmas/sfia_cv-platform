# ─────────────────────────────────────────────────────────────────
#  SFIA Skills Intelligence Platform — Environment Variables
#
#  SETUP:
#    cp .env.example .env
#    # Edit .env with your values
#
#  NEVER commit .env to version control.
#  .env is already in .gitignore.
# ─────────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────────
DB_USER=sfiauser
DB_PASSWORD=sfiapass_change_in_production
DB_NAME=sfiadb
DB_PORT=5432

# ── Parser API ───────────────────────────────────────────────────
PARSER_PORT=8000
LOG_LEVEL=info

# ── Viewer ───────────────────────────────────────────────────────
VIEWER_PORT=5173

# ── Production only ──────────────────────────────────────────────
# API_PUBLIC_URL=https://api.yourdomain.com
